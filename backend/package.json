{
  "name": "deepnetsoft-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "postinstall": "npm run build",
    "clean-install": "npm ci"
  },
  "engines": {
    "node": "18.20.4",
    "npm": "9.0.0"
  },
  "dependencies": {
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "ip-address": "10.1.0",
    "mongoose": "6.12.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "18.19.31",
    "ts-node-dev": "2.0.0",
    "typescript": "5.3.3"
  },
  "overrides": {
    "ip-address": "10.1.0"
  }
}
